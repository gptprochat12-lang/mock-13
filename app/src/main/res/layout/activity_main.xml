<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D1A"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- Header -->
        <ImageView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginTop="16dp"
            android:src="@android:drawable/ic_menu_mylocation"
            android:contentDescription="pin"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Stealth Location"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginTop="4dp"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Root GPS Spoofer v3.0"
            android:textSize="13sp"
            android:textColor="#888888"
            android:layout_marginBottom="16dp"/>

        <!-- Root Status Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1A1A2E"
            android:padding="16dp"
            android:layout_marginBottom="12dp">
            <TextView
                android:id="@+id/tvRootStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔄 Checking..."
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#00FF88"/>
            <TextView
                android:id="@+id/tvRootHint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Please wait..."
                android:textSize="13sp"
                android:textColor="#AAAAAA"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- Status Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1A1A2E"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <!-- Status row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Status"
                    android:textColor="#AAAAAA"
                    android:textSize="14sp"/>
                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔴  INACTIVE"
                    android:textColor="#FF4444"
                    android:textSize="14sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <!-- Live coordinates row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="4dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Coordinates"
                    android:textColor="#AAAAAA"
                    android:textSize="13sp"/>
                <TextView
                    android:id="@+id/tvCurrentCoords"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"/>
            </LinearLayout>

            <!-- Live address row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Location"
                    android:textColor="#AAAAAA"
                    android:textSize="13sp"/>
                <TextView
                    android:id="@+id/tvLocationName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="#00CCFF"
                    android:textSize="13sp"
                    android:textStyle="italic"
                    android:maxWidth="200dp"
                    android:gravity="end"/>
            </LinearLayout>

            <!-- Mode row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Active Mode"
                    android:textColor="#AAAAAA"
                    android:textSize="13sp"/>
                <TextView
                    android:id="@+id/tvModeLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mode: Idle"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Coordinates Input -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1A1A2E"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Enter Coordinates"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Latitude  (-90 to 90)"
                android:textColor="#AAAAAA"
                android:textSize="12sp"
                android:layout_marginBottom="4dp"/>
            <EditText
                android:id="@+id/etLatitude"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="e.g. 32.5765"
                android:textColorHint="#555577"
                android:textColor="#FFFFFF"
                android:background="@drawable/input_bg"
                android:padding="12dp"
                android:inputType="numberDecimal|numberSigned"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Longitude  (-180 to 180)"
                android:textColor="#AAAAAA"
                android:textSize="12sp"
                android:layout_marginBottom="4dp"/>
            <EditText
                android:id="@+id/etLongitude"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="e.g. 74.0650"
                android:textColorHint="#555577"
                android:textColor="#FFFFFF"
                android:background="@drawable/input_bg"
                android:padding="12dp"
                android:inputType="numberDecimal|numberSigned"/>
        </LinearLayout>

        <!-- Custom Presets Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1A1A2E"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="My Saved Locations"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"/>
                <Button
                    android:id="@+id/btnSavePreset"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SAVE PRESET +"
                    android:textSize="11sp"
                    android:backgroundTint="#2255AA"
                    android:textColor="#FFFFFF"/>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tap a location to fill coordinates"
                android:textColor="#777777"
                android:textSize="12sp"
                android:layout_marginBottom="8dp"/>

            <!-- Dynamic preset buttons added here by code -->
            <LinearLayout
                android:id="@+id/presetContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"/>

            <!-- Selected preset label -->
            <TextView
                android:id="@+id/tvPresetLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#00FF88"
                android:textSize="13sp"
                android:layout_marginTop="8dp"/>

        </LinearLayout>

        <!-- Grant Root Button -->
        <Button
            android:id="@+id/btnGrantRoot"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔑 GRANT ROOT PERMISSION"
            android:backgroundTint="#FF6600"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <!-- Start Button -->
        <Button
            android:id="@+id/btnStart"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="▶  START SPOOFING"
            android:backgroundTint="#00AA55"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <!-- Stop Button -->
        <Button
            android:id="@+id/btnStop"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="⏹  STOP"
            android:backgroundTint="#CC2200"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp"
            android:enabled="false"/>

    </LinearLayout>
</ScrollView>
